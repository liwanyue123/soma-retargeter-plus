{
    "initialization_pose": "soma/soma_zero_frame0.bvh",
    "num_initialization_frames": 10,
    "num_stabilization_frames": 5,
    "human_robot_scaler_config": "hightorque_pi_plus/soma_to_pi_plus_scaler_config.json",
    "feet_stabilizer_config": "hightorque_pi_plus/pi_plus_feet_stabilizer_config.json",
    "model_height": 0.80,

    "ik_iterations" : 24,
    "joint_limit_weight": 10.0,
    "smooth_joint_filter_weight": 5.5,
    "collision_weight" : 0.0,
    "enable_post_processing" : true,

    "smooth_joint_filter_objective_body_masks" : {
        "l_shoulder_pitch_link" : 0.1,
        "l_shoulder_roll_link"  : 1.0,
        "l_upper_arm_link"      : 0.3,
        "r_shoulder_pitch_link" : 0.1,
        "r_shoulder_roll_link"  : 1.0,
        "r_upper_arm_link"      : 0.3
    },

    "ik_map": {
        "Hips": {
            "t_body" : "base_link",
            "r_body" : "base_link",
            "t_weight" : 30.0,
            "r_weight" : 2.0
        },
        "Chest": {
            "t_body" : "base_link",
            "r_body" : "base_link",
            "t_weight" : 0.5,
            "r_weight" : 0.3
        },
        "LeftArm": {
            "t_body" : "l_shoulder_roll_link",
            "r_body" : "l_shoulder_roll_link",
            "t_weight" : 1.5,
            "r_weight" : 0.15
        },
        "LeftForeArm": {
            "t_body" : "l_upper_arm_link",
            "r_body" : "l_upper_arm_link",
            "t_weight" : 1.0,
            "r_weight" : 1.0
        },
        "LeftHand": {
            "t_body" : "l_elbow_link",
            "r_body" : "l_elbow_link",
            "t_weight" : 2.0,
            "r_weight" : 1.2
        },
        "RightArm": {
            "t_body" : "r_shoulder_roll_link",
            "r_body" : "r_shoulder_roll_link",
            "t_weight" : 1.5,
            "r_weight" : 0.15
        },
        "RightForeArm": {
            "t_body" : "r_upper_arm_link",
            "r_body" : "r_upper_arm_link",
            "t_weight" : 1.0,
            "r_weight" : 1.0
        },
        "RightHand": {
            "t_body" : "r_elbow_link",
            "r_body" : "r_elbow_link",
            "t_weight" : 2.0,
            "r_weight" : 1.2
        },
        "LeftLeg": {
            "t_body" : "l_hip_roll_link",
            "r_body" : "l_hip_roll_link",
            "t_weight" : 1.5,
            "r_weight" : 0.15
        },
        "LeftShin": {
            "t_body" : "l_calf_link",
            "r_body" : "l_calf_link",
            "t_weight" : 1.0,
            "r_weight" : 1.0
        },
        "LeftFoot": {
            "t_body" : "l_ankle_roll_link",
            "r_body" : "l_ankle_roll_link",
            "t_weight" : 30.0,
            "r_weight" : 2.0
        },
        "RightLeg": {
            "t_body" : "r_hip_roll_link",
            "r_body" : "r_hip_roll_link",
            "t_weight" : 1.5,
            "r_weight" : 0.15
        },
        "RightShin": {
            "t_body" : "r_calf_link",
            "r_body" : "r_calf_link",
            "t_weight" : 1.0,
            "r_weight" : 1.0
        },
        "RightFoot": {
            "t_body" : "r_ankle_roll_link",
            "r_body" : "r_ankle_roll_link",
            "t_weight" : 30.0,
            "r_weight" : 2.0
        }
